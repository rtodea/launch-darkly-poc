# LaunchDarkly SDK Keys
# Found in: LD Dashboard → Account Settings → Projects → Environments
LD_SDK_KEY=sdk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LD_CLIENT_SIDE_ID=xxxxxxxxxxxxxxxxxxxxxxxx

# LaunchDarkly API Access Token
# Found in: LD Dashboard → Account Settings → Authorization → Access Tokens
# Required scopes: writer (for creating flags, metrics, experiments)
LD_API_KEY=api-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# LaunchDarkly Project and Environment
LD_PROJECT_KEY=launch-darkly-poc
LD_ENVIRONMENT_KEY=production
